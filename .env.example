# ─── Supabase (required in production) ──────────────────────────────────────
# Found in: Supabase Dashboard → Settings → API
# These are safe to include in the browser bundle (public keys).
# ─────────────────────────────────────────────────────────────────────────────

VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key-here

# ─── Gemini API key (DEV only — never expose in production builds) ─────────────
# Only used when VITE_SUPABASE_URL is not configured AND import.meta.env.DEV is true.
# In production, direct Gemini access is blocked; the Supabase Edge Function is used
# instead so the API key never appears in the client bundle.
# VITE_GEMINI_API_KEY=your-gemini-api-key-here

# ─── Web Push (VAPID) ──────────────────────────────────────────────────────────
# Public key only — safe in the browser bundle. Generate a keypair with:
#   npx web-push generate-vapid-keys
# Put the PUBLIC key here, and set the PRIVATE key + subject as Supabase secrets:
#   supabase secrets set VAPID_PUBLIC_KEY=<public>
#   supabase secrets set VAPID_PRIVATE_KEY=<private>
#   supabase secrets set VAPID_SUBJECT=mailto:you@example.com
#   supabase secrets set PUSH_TRIGGER_SECRET=<random-long-string>
VITE_VAPID_PUBLIC_KEY=your-vapid-public-key-here
